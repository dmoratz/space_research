"""
analyze_book.py
---------------
Sends individual book chapters to Google Gemini and asks a structured set of
NLP research questions about how space is portrayed. Answers are constrained
to predefined options loaded from the project's question-answer set.

Supports both .txt and .pdf chapter files.

Usage:
    # Multiple chapter files (txt or pdf, can mix):
    python analyze_book.py --book-title "Leviathan Wakes" \
                           --chapters ch01.txt ch02.pdf ch03.txt \
                           --output results.csv

    # Single chapter via stdin:
    cat chapter3.txt | python analyze_book.py --book-title "Dune" \
                                               --chapter-label "Chapter 3"

    # Resume after a crash (skips already-completed chapters):
    python analyze_book.py --book-title "Dune" \
                           --chapters ch*.txt \
                           --output results.csv --resume

Environment:
    GEMINI_API_KEY   – required, your Google AI Studio / Vertex API key
    GEMINI_MODEL     – optional, defaults to gemini-2.0-flash
"""

import argparse
import csv
import json
import os
import sys
import time
from pathlib import Path

from google import genai
import openpyxl

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

DEFAULT_MODEL = "gemini-2.0-flash"
QUESTIONS_FILE = Path(__file__).parent / "data" / "nlp_question_answer_set.xlsx"

# How long to wait between API calls to avoid rate-limiting (seconds)
REQUEST_DELAY = 1.0

# Max retries on transient API errors
MAX_RETRIES = 3

# Rough token estimate: 1 token ≈ 4 characters for English text.
# Gemini models accept up to ~1M tokens, but we set a conservative
# per-chapter warning threshold to catch garbage input early.
CHARS_PER_TOKEN = 4
TOKEN_WARN_THRESHOLD = 200_000   # warn if a single chapter exceeds this
TOKEN_HARD_LIMIT = 900_000       # refuse if a chapter would blow the context


# ---------------------------------------------------------------------------
# File reading (txt + pdf)
# ---------------------------------------------------------------------------

def read_chapter_file(path: Path) -> str:
    """
    Read a chapter file and return its text content.
    Supports .txt and .pdf files.
    """
    suffix = path.suffix.lower()

    if suffix == ".txt":
        return _read_txt(path)
    elif suffix == ".pdf":
        return _read_pdf(path)
    else:
        raise ValueError(
            f"Unsupported file type '{suffix}' for {path}. "
            f"Use .txt or .pdf files."
        )


def _read_txt(path: Path) -> str:
    """Read a plain-text file, trying common encodings."""
    for encoding in ("utf-8", "utf-8-sig", "latin-1", "cp1252"):
        try:
            return path.read_text(encoding=encoding)
        except UnicodeDecodeError:
            continue
    # Last resort: read as latin-1 which never fails
    return path.read_text(encoding="latin-1")


def _read_pdf(path: Path) -> str:
    """Extract text from a PDF using PyMuPDF."""
    try:
        import fitz  # PyMuPDF
    except ImportError:
        print(
            "ERROR: PyMuPDF is required for PDF support.\n"
            "       Install it with:  pip install pymupdf"
        )
        sys.exit(1)

    doc = fitz.open(str(path))
    pages = []
    for page in doc:
        text = page.get_text("text")
        if text.strip():
            pages.append(text)
    doc.close()

    if not pages:
        raise ValueError(f"No extractable text found in {path}. Is it a scanned PDF?")

    return "\n\n".join(pages)


# ---------------------------------------------------------------------------
# Token estimation & guardrails
# ---------------------------------------------------------------------------

def estimate_tokens(text: str) -> int:
    """Rough token count (1 token ≈ 4 chars for English)."""
    return len(text) // CHARS_PER_TOKEN


def check_chapter_size(text: str, label: str) -> None:
    """
    Warn or abort if a chapter is unusually large.
    This catches cases like accidentally passing an entire book as one chapter.
    """
    tokens = estimate_tokens(text)
    chars = len(text)
    words = len(text.split())

    if tokens > TOKEN_HARD_LIMIT:
        print(
            f"\nERROR: '{label}' is extremely large "
            f"(~{words:,} words, ~{tokens:,} est. tokens).\n"
            f"This likely means a full book was passed as a single chapter.\n"
            f"Split the text into individual chapters and retry."
        )
        sys.exit(1)

    if tokens > TOKEN_WARN_THRESHOLD:
        print(
            f"\n  WARNING: '{label}' is very large "
            f"(~{words:,} words, ~{tokens:,} est. tokens).\n"
            f"  The analysis will proceed, but results may be less precise\n"
            f"  for very long inputs. Consider splitting into smaller chunks."
        )


# ---------------------------------------------------------------------------
# Load questions from the xlsx
# ---------------------------------------------------------------------------

def load_questions(path: Path = QUESTIONS_FILE) -> list[dict]:
    """
    Returns a list of dicts, each with:
        - number:          int
        - criteria:        str   (full question text)
        - criteria_short:  str   (abbreviated label)
        - answer_options:  list[str]  (valid answer choices)
    """
    wb = openpyxl.load_workbook(path)
    ws = wb.active

    questions = []
    for row in ws.iter_rows(min_row=4, min_col=1, max_col=5, values_only=True):
        # Columns: A(skip), B = #, C = Criteria, D = Criteria Short, E = Answer Options
        _, num, crit, short, opts = row

        if num is None or crit is None:
            continue

        answer_options = [o.strip() for o in opts.split(";") if o.strip()] if opts else []

        questions.append({
            "number": int(num),
            "criteria": crit.strip(),
            "criteria_short": short.strip() if short else crit.strip(),
            "answer_options": answer_options,
        })

    wb.close()
    return questions


# ---------------------------------------------------------------------------
# Gemini interaction
# ---------------------------------------------------------------------------

def create_gemini_client(api_key: str | None = None) -> genai.Client:
    """Create and return a reusable Gemini client."""
    key = api_key or os.environ.get("GEMINI_API_KEY")
    if not key:
        print("ERROR: provide --api-key or set the GEMINI_API_KEY env variable.")
        sys.exit(1)
    return genai.Client(api_key=key)


def build_prompt(chapter_text: str, question: dict) -> str:
    """
    Constructs the prompt sent to Gemini for a single question about a
    single chapter.  The model is asked to return JSON so answers are
    machine-parseable.

    IMPORTANT: Each prompt is self-contained — no conversation history or
    prior chapter context is carried between calls.  This ensures each
    chapter × question pair is evaluated independently.
    """
    options_str = "\n".join(f"  - {opt}" for opt in question["answer_options"])

    return f"""You are a literary-analysis assistant helping researchers study how
science-fiction books portray outer space.

Below is a chapter from a science-fiction novel.  Read it carefully, then
answer the research question.  You MUST choose exactly ONE answer from the
provided options.  If you are genuinely unsure, choose "Other / Unsure".

Return your response as JSON with two keys:
  "answer"       – the exact text of the chosen option (copy it verbatim)
  "justification" – 1-3 sentences explaining why you chose that answer,
                    citing specific passages or details from the chapter.

---
CHAPTER TEXT:
{chapter_text}
---

RESEARCH QUESTION:
{question["criteria"]}

ANSWER OPTIONS:
{options_str}

Respond ONLY with the JSON object, no markdown fencing."""


def query_gemini(
    client: genai.Client,
    prompt: str,
    model_name: str = DEFAULT_MODEL,
) -> dict:
    """
    Sends a prompt to Gemini and returns the parsed JSON response.
    Retries on transient failures with exponential backoff.
    """
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            response = client.models.generate_content(
                model=model_name,
                contents=prompt,
            )

            # Handle cases where the model returns nothing
            if not response.text:
                return {
                    "answer": "ERROR",
                    "justification": "(model returned empty response)",
                }

            text = response.text.strip()

            # Strip markdown code fences if the model adds them anyway
            if text.startswith("```"):
                text = text.split("\n", 1)[1]   # drop opening fence line
                text = text.rsplit("```", 1)[0] # drop closing fence
                text = text.strip()

            return json.loads(text)

        except json.JSONDecodeError:
            # Model returned non-JSON — wrap it as best-effort
            return {
                "answer": text,
                "justification": "(model did not return valid JSON)",
            }

        except Exception as e:
            if attempt < MAX_RETRIES:
                wait = 2 ** attempt
                print(f"  [retry {attempt}/{MAX_RETRIES}] {e} — waiting {wait}s")
                time.sleep(wait)
            else:
                # Return an error row instead of crashing the whole run
                return {
                    "answer": "API_ERROR",
                    "justification": f"(failed after {MAX_RETRIES} retries: {e})",
                }

    return {"answer": "ERROR", "justification": "Max retries exceeded"}


# ---------------------------------------------------------------------------
# Answer validation
# ---------------------------------------------------------------------------

def validate_answer(answer: str, valid_options: list[str]) -> str:
    """
    Check whether the model's answer exactly matches one of the allowed
    options.  If not, try a fuzzy match (case-insensitive, stripped).
    Returns the canonical option text, or the original answer prefixed
    with [UNMATCHED] so the researcher can review it.
    """
    # Exact match
    if answer in valid_options:
        return answer

    # Case-insensitive / whitespace-insensitive match
    answer_norm = answer.strip().lower()
    for opt in valid_options:
        if opt.strip().lower() == answer_norm:
            return opt  # return the canonical version

    # Substring containment — model sometimes adds extra words
    for opt in valid_options:
        if opt.strip().lower() in answer_norm or answer_norm in opt.strip().lower():
            return opt

    return f"[UNMATCHED] {answer}"


# ---------------------------------------------------------------------------
# Analyze a single chapter against all questions
# ---------------------------------------------------------------------------

def analyze_chapter(
    client: genai.Client,
    chapter_text: str,
    chapter_label: str,
    book_title: str,
    questions: list[dict],
    model_name: str = DEFAULT_MODEL,
) -> list[dict]:
    """
    Returns one result row per question for this chapter.
    Each question is sent as a completely independent API call —
    no context carries over between questions or chapters.
    """
    results = []

    for q in questions:
        print(f"  Q{q['number']:>2}: {q['criteria_short'][:60]}...")
        prompt = build_prompt(chapter_text, q)
        resp = query_gemini(client, prompt, model_name=model_name)

        raw_answer = resp.get("answer", "")
        validated_answer = validate_answer(raw_answer, q["answer_options"])

        if validated_answer.startswith("[UNMATCHED]"):
            print(f"        ⚠ answer did not match options: {raw_answer[:80]}")

        results.append({
            "book_title": book_title,
            "chapter": chapter_label,
            "question_number": q["number"],
            "question": q["criteria_short"],
            "answer": validated_answer,
            "raw_answer": raw_answer,
            "justification": resp.get("justification", ""),
        })

        time.sleep(REQUEST_DELAY)

    return results


# ---------------------------------------------------------------------------
# CSV output
# ---------------------------------------------------------------------------

CSV_COLUMNS = [
    "book_title",
    "chapter",
    "question_number",
    "question",
    "answer",
    "raw_answer",
    "justification",
]


def write_csv(rows: list[dict], path: Path, append: bool = False):
    """Write (or append) result rows to a CSV file."""
    mode = "a" if append else "w"
    file_exists = path.exists() and path.stat().st_size > 0

    with open(path, mode, newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_COLUMNS)
        if not (append and file_exists):
            writer.writeheader()
        writer.writerows(rows)

    print(f"  → wrote {len(rows)} rows to {path}")


def load_completed_chapters(path: Path) -> set[str]:
    """
    Read an existing results CSV and return the set of chapter labels
    that already have a full set of results.  Used for --resume.
    """
    if not path.exists():
        return set()

    chapter_counts: dict[str, int] = {}
    try:
        with open(path, "r", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            for row in reader:
                ch = row.get("chapter", "")
                chapter_counts[ch] = chapter_counts.get(ch, 0) + 1
    except Exception:
        return set()

    return set(chapter_counts.keys())


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def parse_args():
    p = argparse.ArgumentParser(
        description="Analyze sci-fi book chapters with Gemini for space-portrayal research."
    )
    p.add_argument(
        "--book-title", required=True,
        help="Title of the book being analyzed.",
    )
    p.add_argument(
        "--chapters", nargs="+", type=Path,
        help="Paths to chapter files (.txt or .pdf).",
    )
    p.add_argument(
        "--chapter-label", default="Chapter 1",
        help="Label for stdin input when --chapters is not used.",
    )
    p.add_argument(
        "--output", type=Path, default=Path("results.csv"),
        help="Output CSV path (default: results.csv).",
    )
    p.add_argument(
        "--append", action="store_true",
        help="Append to the output CSV instead of overwriting.",
    )
    p.add_argument(
        "--resume", action="store_true",
        help="Skip chapters that already appear in the output CSV. "
             "Useful for resuming after a crash.",
    )
    p.add_argument(
        "--model", default=os.environ.get("GEMINI_MODEL", DEFAULT_MODEL),
        help=f"Gemini model name (default: {DEFAULT_MODEL}).",
    )
    p.add_argument(
        "--api-key",
        default=os.environ.get("GEMINI_API_KEY"),
        help="Gemini API key (or set GEMINI_API_KEY env var).",
    )
    p.add_argument(
        "--questions-file", type=Path, default=QUESTIONS_FILE,
        help="Path to the question-answer xlsx file.",
    )
    return p.parse_args()


def main():
    args = parse_args()

    # Create a single reusable client for all API calls
    client = create_gemini_client(args.api_key)

    # Load questions
    questions = load_questions(args.questions_file)
    print(f"Loaded {len(questions)} questions from {args.questions_file}")

    # If resuming, figure out which chapters are already done
    completed = set()
    if args.resume:
        completed = load_completed_chapters(args.output)
        if completed:
            print(f"Resume mode: skipping {len(completed)} already-completed chapter(s)")

    all_results = []

    if args.chapters:
        # Validate all files exist before starting any API calls
        missing = [p for p in args.chapters if not p.exists()]
        if missing:
            print("ERROR: the following chapter files were not found:")
            for m in missing:
                print(f"  - {m}")
            sys.exit(1)

        for i, chap_path in enumerate(args.chapters, 1):
            label = chap_path.stem  # e.g. "ch01"

            # Skip if already completed (resume mode)
            if label in completed:
                print(f"\n[{i}/{len(args.chapters)}] {label} — already done, skipping")
                continue

            print(f"\n[{i}/{len(args.chapters)}] {label} ({chap_path})")

            # Read the file (txt or pdf)
            try:
                text = read_chapter_file(chap_path)
            except ValueError as e:
                print(f"  ERROR reading file: {e}")
                continue

            if not text.strip():
                print(f"  WARNING: {chap_path} is empty, skipping")
                continue

            # Size guardrails
            check_chapter_size(text, label)
            tokens_est = estimate_tokens(text)
            words = len(text.split())
            print(f"  {words:,} words (~{tokens_est:,} tokens)")

            # Analyze
            rows = analyze_chapter(
                client, text, label, args.book_title, questions,
                model_name=args.model,
            )
            all_results.extend(rows)

            # Checkpoint: write after each chapter so progress isn't lost
            # on a crash.  First chapter writes header; subsequent append.
            is_first_write = (i == 1 and not args.resume) or (
                args.resume and not completed
            )
            write_csv(
                rows, args.output,
                append=not is_first_write or args.append,
            )

    else:
        # Read a single chapter from stdin
        print(f"\n--- reading chapter from stdin ({args.chapter_label}) ---")
        text = sys.stdin.read()
        if not text.strip():
            print("ERROR: no text received on stdin.")
            sys.exit(1)

        check_chapter_size(text, args.chapter_label)

        rows = analyze_chapter(
            client, text, args.chapter_label, args.book_title, questions,
            model_name=args.model,
        )
        all_results.extend(rows)
        write_csv(all_results, args.output, append=args.append)

    # Summary
    errors = sum(1 for r in all_results if r["answer"].startswith(("API_ERROR", "ERROR")))
    unmatched = sum(1 for r in all_results if r["answer"].startswith("[UNMATCHED]"))
    print(f"\n{'='*60}")
    print(f"Done — {len(all_results)} total rows in {args.output}")
    if errors:
        print(f"  ⚠ {errors} question(s) hit API errors")
    if unmatched:
        print(f"  ⚠ {unmatched} answer(s) didn't match predefined options")
    print(f"{'='*60}")


if __name__ == "__main__":
    main()
